{
    "name": "fileroll/fileroll",
    "description": "Personal cloud storage application with WebDAV support",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.0",
        "sabre/dav": "^4.7",
        "sabre/uri": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "FileRoll\\": "src/"
        },
        "files": [
            "lang/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "FileRoll\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    }
}
